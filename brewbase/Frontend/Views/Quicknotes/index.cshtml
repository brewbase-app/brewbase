<div style="display:flex; gap:50px; align-items:flex-start;">

    <!-- LEFT -->
    <div style="flex:2;">
        <h2 style="margin-bottom:25px;">QuickNotes</h2>

        <textarea placeholder="Zacznij pisać..."
                  style="
                    width:100%;
                    height:320px;
                    background:#FFFFFF;
                    border:1px solid #E5E5E5;
                    border-radius:16px;
                    padding:18px;
                    font-size:15px;
                    outline:none;
                    resize:none;
                  ">
        </textarea>

        <button style="
            margin-top:20px;
            background:#111111;
            color:white;
            border:none;
            padding:10px 22px;
            border-radius:12px;
            cursor:pointer;
            transition:0.2s;
        "
                onmouseover="this.style.opacity='0.8'"
                onmouseout="this.style.opacity='1'"
        >
            Zapisz
        </button>
    </div>

    <!-- RIGHT -->
    <div style="flex:1;">
        <h3 style="margin-bottom:25px;">Twoje notatki</h3>

        <div style="
            background:#FFFFFF;
            padding:16px;
            border-radius:14px;
            border:1px solid #E5E5E5;
            margin-bottom:12px;
        ">
            Aeropress – 15g / 250ml
        </div>

        <div style="
            background:#FFFFFF;
            padding:16px;
            border-radius:14px;
            border:1px solid #E5E5E5;
            margin-bottom:12px;
        ">
            Etiopia – test smaku
        </div>

        <div style="
            background:#FFFFFF;
            padding:16px;
            border-radius:14px;
            border:1px solid #E5E5E5;
        ">
            Cupping sesja
        </div>

    </div>

</div>