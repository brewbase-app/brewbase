<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <title>BrewBase</title>

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        html, body {
            margin: 0;
            padding: 0;
            background-color: #F7F7F7;
            font-family: 'Inter', sans-serif;
        }

        body {
            display: flex;
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            height: 100vh;
            background-color: #0F0F0F;
            color: #FFFFFF;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 40px;
        }

        .menu {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .menu a {
            color: #BFBFBF;
            text-decoration: none;
            font-size: 15px;
            transition: 0.2s;
        }

        .menu a:hover {
            color: #FFFFFF;
        }

        /* CONTENT */
        .content {
            flex: 1;
            padding: 60px;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 1100px;
        }
    </style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
    <div class="logo">BrewBase</div>

    <div class="menu">
        <a href="/Dashboard">Dashboard</a>
        <a href="/Recipes">Receptury</a>
        <a href="/Cupping">Cupping</a>
        <a href="/Wikipedia">Wikipedia</a>
        <a href="/QuickNotes">QuickNotes</a>
    </div>
</div>

<!-- CONTENT -->
<div class="content">
    <div class="container">
        @RenderBody()
    </div>
</div>

</body>
</html>